{
  "title": "Zeus Infrastructure Health",
  "panels": [
    {
      "type": "graph",
      "title": "EC2 CPU Utilization",
      "targets": [
        { "expr": "aws_ec2_cpuutilization_average", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "title": "Active Kubernetes Pods",
      "targets": [
        { "expr": "sum(kube_pod_status_phase{phase='Running'})", "refId": "B" }
      ]
    }
  ]
}
